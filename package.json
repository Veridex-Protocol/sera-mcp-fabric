{
  "name": "@veridex/sera-mcp-fabric",
  "version": "0.1.0",
  "description": "Veridex-native rebuild of sera-mcp with typed tools, policy-aware execution, MCP compatibility, and exact upstream handler parity.",
  "license": "MIT",
  "author": "Veridex Team",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "sera-mcp-fabric": "dist/cli/index.mjs",
    "sera-mcp-veridex": "dist/mcp/stdio.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.mjs",
      "require": "./dist/config/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.mjs",
      "require": "./dist/tools/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.mjs",
      "require": "./dist/mcp/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.js"
    },
    "./upstream": {
      "types": "./dist/upstream-exports.d.ts",
      "import": "./dist/upstream-exports.mjs",
      "require": "./dist/upstream-exports.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@veridex/agent-security": "^0.1.3",
    "@veridex/agents": "^0.1.6",
    "@veridex/agents-treasury": "^0.1.1",
    "better-sqlite3": "^12.10.0",
    "ethers": "^6.13.4",
    "undici": "^6.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "veridex",
    "agents",
    "sera",
    "mcp",
    "stablecoins",
    "fx",
    "execution"
  ]
}
