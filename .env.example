### Required: pick one LLM provider
ANTHROPIC_API_KEY=sk-ant-...          # Claude Sonnet 4.6 (recommended)
# OPENAI_API_KEY=sk-...               # or GPT-5.4

# ─── Network ──────────────────────────────────────────────
# Choose 'mainnet' or 'sepolia'. Base URL is hardcoded per network.
SERA_NETWORK=mainnet

# ─── Auth (only required for /balances, /orders, treasury, settlement) ─
SERA_API_KEY=
SERA_API_SECRET=

# ─── Signer mode ──────────────────────────────────────────
# 'external' → server NEVER signs. Tools return route_params for the
#              agent's wallet to sign elsewhere. Safe default.
# 'local'    → server holds SIGNER_PRIVATE_KEY and signs in-process.
#              Enables convert_and_send. Only use on a trusted server.
# 'readonly' → all execution tools refuse. Discovery + analytics only.
SERA_SIGNER_MODE=external
SIGNER_PRIVATE_KEY=

# ─── Policy preset ─────────────────────────────────────────
# Pre-baked bundles. Override individual fields below.
#   starter   → USDC/USDT only, $1k per-tx, $5k daily
#   standard  → 7 stablecoins, $5k per-tx, $50k daily, 0bps tolerance
#   sg-retail → USDC/USDT/XSGD, $2k per-tx, $10k daily
#   open      → no caps (DO NOT USE in distribution)
POLICY_PRESET=standard

# ─── Policy overrides (each beats the preset value if set) ─
# All numeric values are STRICTLY validated at boot. NaN, "5k", or out-of-range
# values fail closed and the server refuses to start (no silent disabled caps).
POLICY_ALLOWED_SYMBOLS=
POLICY_ALLOWED_RECIPIENTS=
POLICY_MAX_NOTIONAL_USD=
POLICY_DAILY_VOLUME_CAP_USD=
POLICY_DEFAULT_EXPIRATION_SECONDS=120
POLICY_MAX_EXPIRATION_SECONDS=600
# How many bps to LOWER minOutputAmount below Sera's quoted minimum.
# Default 0 — only loosen when you explicitly need to. Capped at 500bps.
POLICY_OUTPUT_TOLERANCE_BPS=

# ─── Daily volume persistence ──────────────────────────────
# When true (default), the rolling 24h volume cap is persisted to SQLite so
# it survives process restarts. Requires SERA_HISTORY_DB to be set.
POLICY_PERSIST_DAILY_VOLUME=true

# ─── Dry-run kill-switch ───────────────────────────────────
# 'true' → all execute_swap calls refuse. Useful for paper-trading the policy.
POLICY_DRY_RUN=false

# ─── History persistence (optional) ────────────────────────
# Set to a writable file path to enable fx_history / fx_volatility / corridor_pnl
# AND to enable persistent daily-volume enforcement. The file is chmod 0600 on first open.
SERA_HISTORY_DB=

# When true (default), owner_address is SHA-256 hashed before logging. Disable
# only if you need address-level reconciliation locally and accept the privacy cost.
SERA_HISTORY_HASH_OWNER=true

# ─── Logging ───────────────────────────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info

# ─── Advanced / Sera-internal dev only ─────────────────────
# DO NOT enable these unless you know exactly what you're doing.
# Three layers of friction — even override is bounded to *.sera.cx unless
# the third gate (ALLOW_NON_SERA) is also set.
SERA_BASE_URL_ALLOW_CUSTOM=false
SERA_BASE_URL_ALLOW_NON_SERA=false
SERA_BASE_URL=
